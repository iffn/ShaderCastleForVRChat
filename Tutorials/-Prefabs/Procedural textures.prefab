    - target: {fileID: 7116856329258836659, guid: 3b78f404deb68354e9b08eaf5d093c61,
        type: 3}
      propertyPath: m_AnchorMax.y
      value: 0
      objectReference: {fileID: 0}
    - target: {fileID: 7190096166537646900, guid: 3b78f404deb68354e9b08eaf5d093c61,
        type: 3}
      propertyPath: m_text
      value: "Shader \"ShaderCastle/Tutorials/ProceduralTextures/Voronoi2D\"\r\n{\r\n   
        Properties\r\n    {\r\n        _zoom (\"Zoom\", float) = 1\r\n    }\r\n   
        SubShader\r\n    {\r\n        Pass\r\n        {\r\n            CGPROGRAM\r\n           
        #pragma vertex vert\r\n            #pragma fragment frag\r\n            #pragma
        target 3.5\r\n\r\n            float _zoom;\r\n\r\n            struct appdata
        {\r\n                float4 vertex : POSITION;\r\n            };\r\n\r\n           
        struct v2f {\r\n                float4 pos : SV_POSITION;\r\n               
        float4 vertex : TEXCOORD0;\r\n            };\r\n\r\n            v2f vert
        (appdata v) {\r\n                v2f o;\r\n                o.vertex = v.vertex;\r\n               
        o.pos = UnityObjectToClipPos(v.vertex);\r\n                return o;\r\n           
        }\r\n\r\n            float hash11(float p) {\r\n                uint h =
        asuint(p);\r\n\r\n                h ^= 0x27D4EB2DU; \r\n\r\n               
        h = h * 1103515245U + 12345U;\r\n                h ^= (h >> 16);\r\n               
        h *= 0x85ebca6bU;\r\n                h ^= (h >> 13);\r\n                h
        *= 0xc2b2ae35U;\r\n                h ^= (h >> 16);\r\n\r\n               
        return float(h & 0x00ffffffu) / float(0x01000000u);\r\n            }\r\n\r\n           
        float3 voronoi2D(float2 position) {\r\n                float2 baseCell =
        floor(position);\r\n\r\n                float closestDistance = 8.0;\r\n               
        float secondClosestDistance = 8.0;\r\n                float closestSeed =
        0;\r\n\r\n                [unroll]\r\n                for(int y = -1; y <=
        1; y++) {\r\n                    [unroll]\r\n                    for(int
        x = -1; x <= 1; x++) {\r\n                        float2 cellOffset = float2(x,
        y);\r\n                        float2 cell = baseCell + cellOffset;\r\n                       
        float seed = hash11(cell.x) + cell.y;\r\n                        \r\n                       
        float2 randomOffset = float2(\r\n                            hash11(seed
        + 111.111),\r\n                            hash11(seed + 222.222)\r\n                       
        );\r\n\r\n                        float2 cellPosition = cell + randomOffset;\r\n                       
        float2 distanceToCell = cellPosition - position;\r\n                       
        float distance = length(distanceToCell);\r\n\r\n                        if(distance
        < closestDistance) {\r\n                            secondClosestDistance
        = closestDistance;\r\n                            closestDistance = distance;\r\n                           
        closestSeed = seed;\r\n                        } else if (distance < secondClosestDistance)
        {\r\n                            secondClosestDistance = distance;\r\n                       
        }\r\n                    }\r\n                }\r\n\r\n                float
        edgeDist = secondClosestDistance - closestDistance;\r\n                \r\n               
        float cellID = hash11(closestSeed);\r\n\r\n                return float3(closestDistance,
        cellID, edgeDist);\r\n            }\r\n            \r\n            half4
        frag (v2f i) : SV_Target {\r\n                float2 pos2D = i.vertex.xy;\r\n               
        pos2D *= _zoom;\r\n\r\n                half3 color = voronoi2D(pos2D);\r\n               
        return half4(color.rgb, 1.0);\r\n            }\r\n\r\n            ENDCG\r\n       
        }\r\n    }\r\n}\r\n\u200B"
      objectReference: {fileID: 0}
