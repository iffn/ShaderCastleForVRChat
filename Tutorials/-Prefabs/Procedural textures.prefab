PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 1596880391931599823}
    m_Modifications:
    - target: {fileID: 707830014532808122, guid: 3b78f404deb68354e9b08eaf5d093c61,
        type: 3}
      propertyPath: m_Material
