    - target: {fileID: 8026314177545236412, guid: 3b78f404deb68354e9b08eaf5d093c61,
        type: 3}
      propertyPath: m_text
      value: "Shader <color=#D69D85>\"ShaderCastle/Tutorials/ProceduralTextures/RandomColor\"</color>\r\n{\r\n   
        Properties\r\n    {\r\n        _zoom (<color=#D69D85>\"Zoom\"</color>, float)
        = 1\r\n    }\r\n    SubShader\r\n    {\r\n        Pass\r\n        {\r\n           
        CGPROGRAM\r\n            #pragma vertex vert\r\n            #pragma fragment
        frag\r\n            #pragma target 3.5\r\n\r\n            float _zoom;\r\n\r\n           
        struct appdata {\r\n                float4 vertex : POSITION;\r\n           
        };\r\n\r\n            struct v2f {\r\n                float4 pos : SV_POSITION;\r\n               
        float4 vertex : TEXCOORD0;\r\n            };\r\n\r\n            v2f vert
        (appdata v) {\r\n                v2f o;\r\n                o.vertex = v.vertex;\r\n               
        o.pos = UnityObjectToClipPos(v.vertex);\r\n                return o;\r\n           
        }\r\n            \r\n            float hash11(float p) {\r\n               
        uint h = asuint(p);\r\n                \r\n                h ^= 0x27D4EB2DU;
        \r\n                \r\n                h = h * 1103515245U + 12345U;\r\n               
        h ^= (h >> 16);\r\n                h *= 0x85ebca6bU;\r\n                h
        ^= (h >> 13);\r\n                h *= 0xc2b2ae35U;\r\n                h ^=
        (h >> 16);\r\n                \r\n                return <color=#569CD6>float</color>(h
        & 0x00ffffffu) / <color=#569CD6>float</color>(0x01000000u);\r\n           
        }\r\n            \r\n            half4 frag (<color=#569CD6>v2f</color> i)
        : SV_Target {\r\n                float2 pos2D = i.<color=#569CD6>vertex</color>.xy;\r\n               
        pos2D *= _zoom;\r\n\r\n                float2 gridID = floor(pos2D);\r\n\r\n               
        <color=#569CD6>float</color> randomSeed01 = hash11(hash11(gridID.x) + gridID.y);\r\n\r\n               
        <color=#569CD6>float</color> r = randomSeed01;\r\n                <color=#569CD6>float</color>
        g = hash11(r);\r\n                <color=#569CD6>float</color> b = hash11(g);\r\n\r\n               
        half3 color = half3(r, g, b);\r\n                return half4(color, 1.0);\r\n           
        }\r\n\r\n            <color=#569CD6>ENDCG</color>\r\n        }\r\n    }\r\n}\r\n"
      objectReference: {fileID: 0}
