    - target: {fileID: 1415808747208185003, guid: 3b78f404deb68354e9b08eaf5d093c61,
        type: 3}
      propertyPath: m_Text
      value: "Shader \"ShaderCastle/Tutorials/ProceduralTextures/ValueNoise2D\"\r\n{\r\n   
        Properties\r\n    {\r\n        _zoom (\"Zoom\", float) = 1\r\n    }\r\n   
        SubShader\r\n    {\r\n        Pass\r\n        {\r\n            CGPROGRAM\r\n           
        #pragma vertex vert\r\n            #pragma fragment frag\r\n            #pragma
        target 3.5\r\n\r\n            float _zoom;\r\n\r\n            struct appdata
        {\r\n                float4 vertex : POSITION;\r\n            };\r\n\r\n           
        struct v2f {\r\n                float4 pos : SV_POSITION;\r\n               
        float4 vertex : TEXCOORD0;\r\n            };\r\n\r\n            v2f vert
        (appdata v) {\r\n                v2f o;\r\n                o.vertex = v.vertex;\r\n               
        o.pos = UnityObjectToClipPos(v.vertex);\r\n                return o;\r\n           
        }\r\n\r\n            float hash11(float p) {\r\n\r\n                if(p
        == -0)\r\n                    p = 0;\r\n\r\n                uint h = asuint(p+0.0);\r\n\r\n               
        h ^= 0x27D4EB2DU; \r\n\r\n                h = h * 1103515245U + 12345U;\r\n               
        h ^= (h >> 16);\r\n                h *= 0x85ebca6bU;\r\n                h
        ^= (h >> 13);\r\n                h *= 0xc2b2ae35U;\r\n                h ^=
        (h >> 16);\r\n\r\n                return float(h & 0x00ffffffu) / float(0x01000000u);\r\n           
        }\r\n\r\n            float hash21(float2 p) {\r\n                return hash11(hash11(p.x)
        + p.y);\r\n            }\r\n            \r\n            float valueNoise(float2
        uv) {\r\n                // Base parameters\r\n\t\t\t\tfloat2 i = floor(uv);\r\n\t\t\t\tfloat2
        f = frac(uv);\r\n                float2 u = f*f*(3.0-2.0*f); // Smoothstep
        between 0...1\r\n\r\n                // Random weights\r\n               
        float a = hash21(i + float2(0.0, 0.0));\r\n                float b = hash21(i
        + float2(1.0, 0.0));\r\n                float c = hash21(i + float2(0.0,
        1.0));\r\n                float d = hash21(i + float2(1.0, 1.0));\r\n\r\n               
        // Bilinear interpolation\r\n\t\t\t\tfloat bottom = lerp(a, b, u.x);\r\n\t\t\t\tfloat
        top = lerp(c, d, u.x);\r\n\t\t\t\treturn lerp(bottom, top, u.y);\r\n\t\t\t}\r\n           
        \r\n            half4 frag (v2f i) : SV_Target {\r\n                float2
        pos2D = i.vertex.xy;\r\n                pos2D *= _zoom;\r\n\r\n               
        float noise = valueNoise(pos2D);\r\n\r\n                half3 color = noise.xxx;\r\n\r\n               
        return half4(color.rgb, 1.0);\r\n            }\r\n\r\n            ENDCG\r\n       
        }\r\n    }\r\n}\r\n"
      objectReference: {fileID: 0}
