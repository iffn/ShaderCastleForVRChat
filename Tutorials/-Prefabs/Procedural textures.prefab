        return hash11(hash11(p.x) + p.y);\r\n            }\r\n\r\n            float2
        hash22(float2 p)\r\n            {\r\n                <color=#569CD6>float</color>
        a = hash11(hash11(p.x) + p.y);\r\n                <color=#569CD6>float</color>
        b = hash11(a);\r\n                return float2(a, b);\r\n            }\r\n\r\n           
        <color=#569CD6>float</color> perlinNoise(float2 uv) {\r\n               
        <color=#57A64A>// Base parameters\r</color>\n\t\t\t\tfloat2 i = floor(uv);\r\n\t\t\t\tfloat2
        f = frac(uv);\r\n                float2 u = f*f*(3.0-2.0*f); <color=#57A64A>//
