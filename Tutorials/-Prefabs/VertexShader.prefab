  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 6386476088159276510}
    m_Modifications:
    - target: {fileID: 662025258118020327, guid: 7ffcca573e1296d47a9191342db0701b,
        type: 3}
      propertyPath: m_Materials.Array.data[0]
      value: 
      objectReference: {fileID: 2100000, guid: 631e68f64ab368f4aa6ddb11e3e82523, type: 2}
    - target: {fileID: 3883131558245652288, guid: 7ffcca573e1296d47a9191342db0701b,
        type: 3}
      propertyPath: m_text
      value: "Shader \"ShaderCastle/Tutorials/VertexShader/VerticalBillboard\"\r\n{\r\n   
        SubShader\r\n    {\r\n        Pass\r\n        {\r\n            CGPROGRAM\r\n           
        #pragma vertex vert\r\n            #pragma fragment frag\r\n            \r\n           
        #include \"UnityCG.cginc\"\r\n\r\n            struct appdata {\r\n               
        float4 vertex : POSITION;\r\n            };\r\n\r\n            struct v2f
        {\r\n                float4 pos : SV_POSITION;\r\n            };\r\n\r\n           
        v2f vert (appdata v) {\r\n                v2f o;\r\n\r\n                float3
        worldCenter = float3(unity_ObjectToWorld._m03, unity_ObjectToWorld._m13,
        unity_ObjectToWorld._m23);\r\n                \r\n                float scaleX
        = length(float3(unity_ObjectToWorld._m00, unity_ObjectToWorld._m10, unity_ObjectToWorld._m20));\r\n               
        float scaleY = length(float3(unity_ObjectToWorld._m01, unity_ObjectToWorld._m11,
        unity_ObjectToWorld._m21));\r\n\r\n                float3 lookDir = _WorldSpaceCameraPos
        - worldCenter;\r\n                lookDir.y = 0;\r\n                lookDir
        = normalize(lookDir);\r\n\r\n                float3 worldUp = float3(0, 1,
        0);\r\n                float3 worldRight = normalize(cross(lookDir, worldUp));\r\n\r\n               
        float3 worldPos = worldCenter \r\n                                + worldRight
        * v.vertex.x * scaleX \r\n                                + worldUp * v.vertex.y
        * scaleY;\r\n\r\n                o.pos = mul(UNITY_MATRIX_VP, float4(worldPos,
        1.0));\r\n\r\n                return o;\r\n            }\r\n\r\n           
        half4 frag () : SV_Target {\r\n                half3 color = half3(1.0, 0.0,
        0.0); // Red\r\n                return half4(color, 1.0);\r\n           
        }\r\n            ENDCG\r\n        }\r\n    }\r\n}\r\n\u200B"
      objectReference: {fileID: 0}
    - target: {fileID: 4127777698288987080, guid: 7ffcca573e1296d47a9191342db0701b,
        type: 3}
      propertyPath: m_text
      value: "Shader <color=#D69D85>\"ShaderCastle/Tutorials/VertexShader/VerticalBillboard\"</color>\r\n{\r\n   
        SubShader\r\n    {\r\n        Pass\r\n        {\r\n            CGPROGRAM\r\n           
        #pragma vertex vert\r\n            #pragma fragment frag\r\n            \r\n           
        #include <color=#D69D85>\"UnityCG.cginc\"</color>\r\n\r\n            <color=#569CD6>struct</color>
        <color=#569CD6>appdata</color> {\r\n                float4 <color=#569CD6>vertex</color>
        : POSITION;\r\n            };\r\n\r\n            <color=#569CD6>struct</color>
        <color=#569CD6>v2f</color> {\r\n                float4 pos : SV_POSITION;\r\n           
        };\r\n\r\n            <color=#569CD6>v2f</color> vert (<color=#569CD6>appdata</color>
        v) {\r\n                <color=#569CD6>v2f</color> o;\r\n\r\n               
        float3 worldCenter = float3(unity_ObjectToWorld._m03, unity_ObjectToWorld._m13,
        unity_ObjectToWorld._m23);\r\n                \r\n                <color=#569CD6>float</color>
        scaleX = length(float3(unity_ObjectToWorld._m00, unity_ObjectToWorld._m10,
        unity_ObjectToWorld._m20));\r\n                <color=#569CD6>float</color>
        scaleY = length(float3(unity_ObjectToWorld._m01, unity_ObjectToWorld._m11,
        unity_ObjectToWorld._m21));\r\n\r\n                float3 lookDir = _WorldSpaceCameraPos
        - worldCenter;\r\n                lookDir.y = 0;\r\n                lookDir
        = normalize(lookDir);\r\n\r\n                float3 worldUp = float3(0, 1,
        0);\r\n                float3 worldRight = normalize(cross(lookDir, worldUp));\r\n\r\n               
        float3 worldPos = worldCenter \r\n                                + worldRight
        * v.<color=#569CD6>vertex</color>.x * scaleX \r\n                               
        + worldUp * v.<color=#569CD6>vertex</color>.y * scaleY;\r\n\r\n               
        o.pos = mul(UNITY_MATRIX_VP, float4(worldPos, 1.0));\r\n\r\n               
        return o;\r\n            }\r\n\r\n            half4 frag () : SV_Target {\r\n               
        half3 color = half3(1.0, 0.0, 0.0); <color=#57A64A>// Red\r</color>\n               
        return half4(color, 1.0);\r\n            }\r\n            <color=#569CD6>ENDCG</color>\r\n       
        }\r\n    }\r\n}\r\n"
