    - target: {fileID: 3883131558245652288, guid: 7ffcca573e1296d47a9191342db0701b,
        type: 3}
      propertyPath: m_text
      value: "Shader \"ShaderCastle/Tutorials/VertexShader/Billboard\"\r\n{\r\n   
        SubShader\r\n    {\r\n        Pass\r\n        {\r\n            CGPROGRAM\r\n           
        #pragma vertex vert\r\n            #pragma fragment frag\r\n            \r\n           
        #include \"UnityCG.cginc\"\r\n\r\n            struct appdata {\r\n               
        float4 vertex : POSITION;\r\n            };\r\n\r\n            struct v2f
        {\r\n                float4 pos : SV_POSITION;\r\n            };\r\n\r\n           
        v2f vert (appdata v) {\r\n                v2f o;\r\n\r\n                float
        viewScaleX = length(float3(unity_ObjectToWorld._m00, unity_ObjectToWorld._m10,
        unity_ObjectToWorld._m20));\r\n                float viewScaleY = length(float3(unity_ObjectToWorld._m01,
        unity_ObjectToWorld._m11, unity_ObjectToWorld._m21));\r\n               
        float4 viewPosition = float4(v.vertex.x * viewScaleX, v.vertex.y * viewScaleY,
        0, 0);\r\n\r\n                float4 viewSpaceCenter = mul(UNITY_MATRIX_MV,
        float4(0, 0, 0, 1));\r\n                float4 viewPos = viewSpaceCenter
        + viewPosition;\r\n\r\n                o.pos = mul(UNITY_MATRIX_P, viewPos);\r\n               
        return o;\r\n            }\r\n\r\n            half4 frag () : SV_Target {\r\n               
        half3 color = half3(1.0, 0.0, 0.0); // Red\r\n                return half4(color,
        1.0);\r\n            }\r\n            ENDCG\r\n        }\r\n    }\r\n}\r\n\u200B"
      objectReference: {fileID: 0}
