    - target: {fileID: 3883131558245652288, guid: 7ffcca573e1296d47a9191342db0701b,
        type: 3}
      propertyPath: m_text
      value: "Shader \"ShaderCastle/Tutorials/VertexShader/CullBack\"\r\n{\r\n   
        SubShader\r\n    {\r\n        Pass\r\n        {\r\n            Cull Back\r\n           
        CGPROGRAM\r\n            #pragma vertex vert\r\n            #pragma fragment
        frag\r\n            \r\n\r\n            struct appdata {\r\n               
        float4 vertex : POSITION;\r\n            };\r\n\r\n            struct v2f
        {\r\n                float4 pos : SV_POSITION;\r\n            };\r\n\r\n           
        v2f vert (appdata v) {\r\n                v2f o;\r\n                \r\n               
        float xOffset = v.vertex.x;\r\n                v.vertex.x = xOffset * sin(_Time.y);\r\n               
        v.vertex.z = xOffset * cos(_Time.y);\r\n\r\n                o.pos = UnityObjectToClipPos(v.vertex);\r\n               
        return o;\r\n            }\r\n\r\n            half4 frag () : SV_Target {\r\n               
        half3 color = half3(1.0, 0.0, 0.0); // Red\r\n                return half4(color,
        1.0);\r\n            }\r\n            ENDCG\r\n        }\r\n    }\r\n}\r\n\u200B"
      objectReference: {fileID: 0}
    - target: {fileID: 4127777698288987080, guid: 7ffcca573e1296d47a9191342db0701b,
        type: 3}
      propertyPath: m_text
      value: "Shader <color=#D69D85>\"ShaderCastle/Tutorials/VertexShader/CullBack\"</color>\r\n{\r\n   
        <color=#569CD6>SubShader</color>\r\n    {\r\n        <color=#569CD6>Pass</color>\r\n       
        {\r\n            Cull Back\r\n            <color=#569CD6>CGPROGRAM</color>\r\n           
        #pragma <color=#569CD6>vertex</color> vert\r\n            #pragma <color=#569CD6>fragment</color>
        frag\r\n            \r\n\r\n            <color=#569CD6>struct</color> <color=#569CD6>appdata</color>
        {\r\n                float4 <color=#569CD6>vertex</color> : POSITION;\r\n           
        };\r\n\r\n            <color=#569CD6>struct</color> <color=#569CD6>v2f</color>
        {\r\n                float4 pos : SV_POSITION;\r\n            };\r\n\r\n           
        <color=#569CD6>v2f</color> vert (<color=#569CD6>appdata</color> v) {\r\n               
        <color=#569CD6>v2f</color> o;\r\n                \r\n                <color=#569CD6>float</color>
        xOffset = v.<color=#569CD6>vertex</color>.x;\r\n                v.<color=#569CD6>vertex</color>.x
        = xOffset * sin(_Time.y);\r\n                v.<color=#569CD6>vertex</color>.z
        = xOffset * cos(_Time.y);\r\n\r\n                o.pos = UnityObjectToClipPos(v.<color=#569CD6>vertex</color>);\r\n               
        return o;\r\n            }\r\n\r\n            half4 frag () : SV_Target {\r\n               
        half3 color = half3(1.0, 0.0, 0.0); <color=#57A64A>// Red\r</color>\n               
        return half4(color, 1.0);\r\n            }\r\n            <color=#569CD6>ENDCG</color>\r\n       
        }\r\n    }\r\n}\r\n"
