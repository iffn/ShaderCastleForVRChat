    - target: {fileID: 3883131558245652288, guid: 7ffcca573e1296d47a9191342db0701b,
        type: 3}
      propertyPath: m_text
      value: "Shader \"ShaderCastle/Tutorials/Color/ColorRGBBoxGamma\"\r\n{\r\n   
        SubShader\r\n    {\r\n        Pass\r\n        {\r\n            Cull Off\r\n           
        CGPROGRAM\r\n            #pragma vertex vert\r\n            #pragma fragment
        frag\r\n\r\n            struct appdata {\r\n                float4 vertex
        : POSITION;\r\n            };\r\n\r\n            struct v2f {\r\n               
        float4 pos : SV_POSITION;\r\n                float4 localPos : TEXCOORD0;\r\n           
        };\r\n\r\n            v2f vert (appdata v) {\r\n                v2f o;\r\n               
        o.localPos = v.vertex;\r\n                o.pos = UnityObjectToClipPos(v.vertex);\r\n               
        return o;\r\n            }\r\n\r\n            half4 frag (v2f i) : SV_Target
        {\r\n                half3 color = half3(i.localPos.xxx + 0.5);\r\n               
        #ifdef UNITY_COLORSPACE_GAMMA\r\n                    color = pow(color, 0.45454545454);
        \r\n                #endif\r\n                return half4(color, 1.0);\r\n           
        }\r\n            ENDCG\r\n        }\r\n    }\r\n}\r\n\u200B"
      objectReference: {fileID: 0}
    - target: {fileID: 4007255147528135500, guid: 7ffcca573e1296d47a9191342db0701b,
        type: 3}
