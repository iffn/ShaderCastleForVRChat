      value: 0
      objectReference: {fileID: 0}
    - target: {fileID: 1415808747208185003, guid: 3b78f404deb68354e9b08eaf5d093c61,
        type: 3}
      propertyPath: m_Text
      value: "Shader \"ShaderCastle/Tutorials/Basics/UVCoordinate\"\r\n{\r\n    SubShader\r\n   
        {\r\n        Pass\r\n        {\r\n            CGPROGRAM\r\n            #pragma
        vertex vert\r\n            #pragma fragment frag\r\n\r\n            // Mesh
        to vertex transfer data\r\n            struct appdata {\r\n               
        float4 vertex : POSITION;\r\n                float2 uv : TEXCOORD0; // Access
        to uv values\r\n            };\r\n\r\n            // Vertex to fragment transfer
        data\r\n            struct v2f {\r\n                float4 pos : SV_POSITION;\r\n               
        float2 uv : TEXCOORD0; // UV transfer data\r\n            };\r\n\r\n           
        // Vertex function\r\n            v2f vert (appdata v) {\r\n               
        v2f o;\r\n                o.pos = UnityObjectToClipPos(v.vertex);\r\n               
        o.uv = v.uv; // Directly transfering uv values from mesh to fragment\r\n               
        return o;\r\n            }\r\n\r\n            // Fragment function accessing
        the UV values\r\n            half4 frag (v2f i) : SV_Target {\r\n               
        half3 color = half3(i.uv, 0.0);\r\n                return half4(color, 1.0);\r\n           
        }\r\n            ENDCG\r\n        }\r\n    }\r\n}\r\n"
      objectReference: {fileID: 0}
    - target: {fileID: 1496588037925710651, guid: 3b78f404deb68354e9b08eaf5d093c61,
        type: 3}
      propertyPath: m_text
      value: 'The vertices of the mesh can hold data, such as UV map coordinates.
        These are interpolated over the surface for each pixel.


        The output
        here is x for red

        and y for green'
      objectReference: {fileID: 0}
