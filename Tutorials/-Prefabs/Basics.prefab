        \"UnityCG.cginc\"\r\n\r\n            sampler2D _MainTex;\r\n            float4
        _MainTex_ST;\r\n\r\n            struct appdata {\r\n                float4
        vertex : POSITION;\r\n                float2 uv : TEXCOORD0;\r\n           
        };\r\n\r\n            struct v2f {\r\n                float4 pos : SV_POSITION;\r\n               
        float2 uv : TEXCOORD0;\r\n            };\r\n\r\n            v2f vert (appdata
        v) {\r\n                v2f o;\r\n                o.pos = UnityObjectToClipPos(v.vertex);\r\n               
        o.uv = TRANSFORM_TEX(v.uv, _MainTex);\r\n                return o;\r\n           
