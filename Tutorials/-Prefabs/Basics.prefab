        frag\r\n\r\n            <color=#57A64A>// Mesh to vertex transfer data\r</color>\n           
        <color=#569CD6>struct</color> <color=#569CD6>appdata</color> {\r\n               
        float4 <color=#569CD6>vertex</color> : POSITION;\r\n                float2
        uv : TEXCOORD0; <color=#57A64A>// Access to uv values\r</color>\n           
        };\r\n\r\n            <color=#57A64A>// Vertex to fragment transfer data\r</color>\n           
        <color=#569CD6>struct</color> <color=#569CD6>v2f</color> {\r\n               
        float4 pos : SV_POSITION;\r\n                float2 uv : TEXCOORD0; <color=#57A64A>//
        UV transfer data\r</color>\n            };\r\n\r\n            <color=#57A64A>//
        Vertex function\r</color>\n            <color=#569CD6>v2f</color> vert (<color=#569CD6>appdata</color>
        v) {\r\n                <color=#569CD6>v2f</color> o;\r\n               
        o.pos = UnityObjectToClipPos(v.<color=#569CD6>vertex</color>);\r\n               
        o.uv = v.uv; <color=#57A64A>// Directly transfering uv values from mesh to
        fragment\r</color>\n                return o;\r\n            }\r\n\r\n           
        <color=#57A64A>// Fragment function accessing the UV values\r</color>\n           
        half4 frag (<color=#569CD6>v2f</color> i) : SV_Target {\r\n               
        half3 color = half3(i.uv, 0.0);\r\n                return half4(color, 1.0);\r\n           
        }\r\n            <color=#569CD6>ENDCG</color>\r\n        }\r\n    }\r\n}\r\n"
