    - target: {fileID: 1415808747208185003, guid: 3b78f404deb68354e9b08eaf5d093c61,
        type: 3}
      propertyPath: m_Text
      value: "Shader \"ShaderCastle/Tutorials/Basics/Time\"\r\n{\r\n    Properties\r\n   
        {\r\n        _MainTex (\"Texture\", 2D) = \"white\" {}\r\n    }\r\n    SubShader\r\n   
        {\r\n        Pass\r\n        {\r\n            CGPROGRAM\r\n            #pragma
        vertex vert\r\n            #pragma fragment frag\r\n\r\n            #include
        \"UnityCG.cginc\"\r\n\r\n            sampler2D _MainTex;\r\n            float4
        _MainTex_ST;\r\n\r\n            struct appdata {\r\n                float4
        vertex : POSITION;\r\n                float2 uv : TEXCOORD0;\r\n           
        };\r\n\r\n            struct v2f {\r\n                float4 pos : SV_POSITION;\r\n               
        float2 uv : TEXCOORD0;\r\n            };\r\n\r\n            v2f vert (appdata
        v) {\r\n                v2f o;\r\n                o.pos = UnityObjectToClipPos(v.vertex);\r\n               
        o.uv = TRANSFORM_TEX(v.uv, _MainTex);\r\n                return o;\r\n           
        }\r\n\r\n            // Fragment function\r\n            half4 frag (v2f
        i) : SV_Target {\r\n                float time = _Time.y * 0.2; // Time in
        seconds stored in _Time.y\r\n                half3 color = tex2D(_MainTex,
        i.uv + time.xx);\r\n                return half4(color, 1.0);\r\n           
        }\r\n            ENDCG\r\n        }\r\n    }\r\n}\r\n"
      objectReference: {fileID: 0}
    - target: {fileID: 1496588037925710651, guid: 3b78f404deb68354e9b08eaf5d093c61,
        type: 3}
      propertyPath: m_text
      value: 'Unity provides different values that can be used in shaders, such as
        the current time.


        It is implemented like this:

        _Time.x
        = t / 20

        _Time.y = t

        _Time.z = t * 2

        _Time.w =
        t * 3'
      objectReference: {fileID: 0}
