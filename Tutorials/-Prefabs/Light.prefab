      objectReference: {fileID: 0}
    - target: {fileID: 2676220887514110487, guid: 7ffcca573e1296d47a9191342db0701b,
        type: 3}
      propertyPath: m_IsActive
      value: 0
      objectReference: {fileID: 0}
    - target: {fileID: 2735085066506440042, guid: 7ffcca573e1296d47a9191342db0701b,
        type: 3}
      propertyPath: m_IsActive
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 3323022602836515612, guid: 7ffcca573e1296d47a9191342db0701b,
        type: 3}
      propertyPath: serializationData.Prefab
      value: 
      objectReference: {fileID: 3323022602836515612, guid: 7ffcca573e1296d47a9191342db0701b,
        type: 3}
    - target: {fileID: 3883131558245652288, guid: 7ffcca573e1296d47a9191342db0701b,
        type: 3}
      propertyPath: m_text
      value: "Shader \"ShaderCastle/Tutorials/Basics/JustRed\"\r\n{\r\n    SubShader\r\n   
        {\r\n        Pass\r\n        {\r\n            CGPROGRAM\r\n            #pragma
        vertex vert // The vertex function is called vert\r\n            #pragma
        fragment frag // The fragment funciton is called frag\r\n\r\n           
        // Mesh to vertex transfer data\r\n            struct appdata {\r\n               
        float4 vertex : POSITION;\r\n            };\r\n\r\n            // Vertex
        to fragment transfer data\r\n            struct v2f {\r\n               
        float4 pos : SV_POSITION;\r\n            };\r\n\r\n            // Vertex
        function\r\n            v2f vert (appdata v) {\r\n                v2f o;\r\n               
        o.pos = UnityObjectToClipPos(v.vertex); // Basic object to clip space transformation\r\n               
        return o;\r\n            }\r\n\r\n            // Fragment function\r\n           
        half4 frag () : SV_Target {\r\n                half3 color = half3(1.0, 0.0,
        0.0); // Red\r\n                return half4(color, 1.0); // 1.0 on alpha
        channel, default for opaque\r\n            }\r\n            ENDCG\r\n       
        }\r\n    }\r\n}\r\n\u200B"
      objectReference: {fileID: 0}
    - target: {fileID: 4007255147528135500, guid: 7ffcca573e1296d47a9191342db0701b,
        type: 3}
      propertyPath: m_AnchorMax.y
      value: 0
      objectReference: {fileID: 0}
    - target: {fileID: 4007255147528135500, guid: 7ffcca573e1296d47a9191342db0701b,
        type: 3}
