    - target: {fileID: 5011955837517992159, guid: 7ffcca573e1296d47a9191342db0701b,
        type: 3}
      propertyPath: m_Text
      value: "Shader \"ShaderCastle/Tutorials/Light/UnityDirectionalLight\"\r\n{\r\n   
        SubShader\r\n    {\r\n        Pass\r\n        {\r\n            CGPROGRAM\r\n           
        #pragma vertex vert\r\n            #pragma fragment frag\r\n            #include
        \"UnityCG.cginc\"\r\n            #include \"Lighting.cginc\"\r\n\r\n           
        struct appdata {\r\n                float4 vertex : POSITION;\r\n               
        float3 normal : NORMAL;\r\n            };\r\n\r\n            struct v2f {\r\n               
        float4 pos : SV_POSITION;\r\n                float3 worldNormal : TEXCOORD0;\r\n           
        };\r\n\r\n            v2f vert (appdata v) {\r\n                v2f o;\r\n               
        o.pos = UnityObjectToClipPos(v.vertex);\r\n                o.worldNormal
        = UnityObjectToWorldNormal(v.normal);\r\n\r\n                return o;\r\n           
        }\r\n\r\n            half4 frag (v2f i) : SV_Target {\r\n               
        float3 worldNormal = normalize(i.worldNormal);\r\n                float3
        _world_light_direction = normalize(_WorldSpaceLightPos0.xyz);\r\n               
        float3 lightColor = _LightColor0.rgb;\r\n\r\n                half3 NdotL
        = dot(worldNormal, _world_light_direction);\r\n                NdotL = saturate(NdotL);\r\n               
        \r\n                half3 diffuse = NdotL * lightColor;\r\n               
        \r\n                return half4(diffuse, 1.0);\r\n            }\r\n           
        ENDCG\r\n        }\r\n    }\r\n}"
      objectReference: {fileID: 0}
