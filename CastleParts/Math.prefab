    - target: {fileID: 2086081743145107749, guid: 7ffcca573e1296d47a9191342db0701b,
        type: 3}
      propertyPath: m_text
      value: "The cross product returns the normal to the plane formed by the other
        2 vectors.\n\nThe direction of the vector depends on the environemnt. Unity
        uses a left handed coordinate system, so the direction is returned as shown.\n\nThe
        distance can be calculated by:\n   length(a) * length(b)\n   * sin(angle
        between a&b)"
      objectReference: {fileID: 0}
